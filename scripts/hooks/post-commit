#!/usr/bin/env sh
# gitsema post-commit hook
#
# Incrementally indexes the latest committed changes so the semantic index
# stays up-to-date after every commit.
#
# Install:
#   cp scripts/hooks/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit
#
# Or use the symlink approach so the script stays in sync with the repo:
#   ln -s ../../scripts/hooks/post-commit .git/hooks/post-commit

set -e

# Only run if gitsema is available on PATH
if ! command -v gitsema > /dev/null 2>&1; then
  echo "[gitsema] skipping post-commit hook: 'gitsema' not found on PATH" >&2
  exit 0
fi

# Only run inside a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  exit 0
fi

# Only run if the index database already exists (i.e. gitsema has been
# initialised for this repo), so a fresh clone does not stall on first commit.
GITSEMA_DB="$(git rev-parse --show-toplevel)/.gitsema/index.db"
if [ ! -f "$GITSEMA_DB" ]; then
  echo "[gitsema] skipping post-commit hook: index not initialised (run 'gitsema index' first)" >&2
  exit 0
fi

echo "[gitsema] indexing latest commit…"
gitsema index --since HEAD~1
